OPENROUTER_API_KEY=sk-or-...
AI_MODEL=anthropic/claude-3.5-sonnet

# Authentik — generate AUTHENTIK_SECRET_KEY with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_PASSWORD=akadmin
AUTHENTIK_BOOTSTRAP_EMAIL=akadmin@local
AUTHENTIK_BOOTSTRAP_TOKEN=

# OIDC — issuer must match the host the browser uses (localhost:9000); JWKS goes via docker net
OIDC_ISSUER=http://localhost:9000/application/o/fts/
OIDC_AUDIENCE=fts-frontend
OIDC_JWKS_URL=http://authentik-server:9000/application/o/fts/jwks/

# Frontend talks to Authentik through the host
VITE_OIDC_AUTHORITY=http://localhost:9000/application/o/fts/
VITE_OIDC_CLIENT_ID=fts-frontend
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
